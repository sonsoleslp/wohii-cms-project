{
  "info": {
    "_postman_id": "65ce6f03-747f-4cf4-9b0f-e4394c02e4a9",
    "name": "CMS Demo API",
    "description": "All routes for the CMS demo project. After running 'Login', the JWT is stored in the {{token}} variable and used by every other request.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "token", "value": "" },
    { "key": "postId", "value": "1" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"new@example.com\",\n  \"password\": \"secret123\",\n  \"name\": \"New User\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json();",
                  "if (data.token) pm.collectionVariables.set('token', data.token);"
                ]
              }
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"example@example.org\",\n  \"password\": \"secret123\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json();",
                  "if (data.token) pm.collectionVariables.set('token', data.token);"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Posts",
      "item": [
        {
          "name": "List (default)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/posts"
          }
        },
        {
          "name": "List (paginated)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/posts?page=1&limit=5"
          }
        },
        {
          "name": "List (keyword search)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/posts?keyword=http&page=1&limit=5"
          }
        },
        {
          "name": "Get by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/posts/{{postId}}"
          }
        },
        {
          "name": "Create (JSON, no image)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/posts",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Hello world\",\n  \"date\": \"2026-04-28\",\n  \"content\": \"My first post\",\n  \"keywords\": [\"intro\", \"hello\"]\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json();",
                  "if (data.id) pm.collectionVariables.set('postId', String(data.id));"
                ]
              }
            }
          ]
        },
        {
          "name": "Create (with image, multipart)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/posts",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "title", "value": "Post with image", "type": "text" },
                { "key": "date", "value": "2026-04-28", "type": "text" },
                { "key": "content", "value": "Has an image attached", "type": "text" },
                { "key": "keywords", "value": "media,image", "type": "text" },
                { "key": "image", "type": "file" }
              ]
            },
            "description": "Pick an image file in the 'image' field. The 'keywords' field is a comma-separated string when sent via multipart."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json();",
                  "if (data.id) pm.collectionVariables.set('postId', String(data.id));"
                ]
              }
            }
          ]
        },
        {
          "name": "Update (JSON, no new image)",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/posts/{{postId}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Updated title\",\n  \"date\": \"2026-04-28\",\n  \"content\": \"Updated content\",\n  \"keywords\": [\"updated\"]\n}"
            }
          }
        },
        {
          "name": "Update (with new image, multipart)",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/posts/{{postId}}",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "title", "value": "Updated with image", "type": "text" },
                { "key": "date", "value": "2026-04-28", "type": "text" },
                { "key": "content", "value": "Now has a new image", "type": "text" },
                { "key": "keywords", "value": "updated,media", "type": "text" },
                { "key": "image", "type": "file" }
              ]
            }
          }
        },
        {
          "name": "Delete",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/posts/{{postId}}"
          }
        }
      ]
    },
    {
      "name": "Likes",
      "item": [
        {
          "name": "Like a post",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/posts/{{postId}}/like"
          }
        },
        {
          "name": "Unlike a post",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/posts/{{postId}}/like"
          }
        }
      ]
    }
  ]
}
